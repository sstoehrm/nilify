#!/usr/bin/env bb

(require '[babashka.deps :as deps])
(deps/add-deps '{:deps {metosin/malli {:mvn/version "0.20.1"}}})

(ns nilify.core
  (:require [clojure.string :as str]))

(defn prompt
  "Join description fragments into one string."
  [& parts]
  (str/join " " parts))

(defn root
  "Spec entry point: return the vector of system nodes as the tree."
  [systems]
  (vec systems))

(ns nilify.cli
  (:require [babashka.http-client :as http]
            [clojure.java.io :as io]
            [clojure.string :as string]
            [malli.core :as m]
            [malli.error :as me]
            [malli.generator :as mg]
            [cheshire.core :as json]))

(def version "0.1.0")
(def repo "sstoehrm/nilify")
(def raw-url (str "https://raw.githubusercontent.com/" repo))

;; ---- Tree spec schemas ----

(def FeatureProps
  [:map
   [:id :keyword]
   [:tech      {:optional true} :string]
   [:desc      {:optional true} :string]
   [:internals {:optional true} [:map-of :any :any]]])

(def Feature [:catn [:tag [:enum :feature]] [:props FeatureProps]])
(def Layer   [:catn [:tag [:enum :layer]] [:features [:+ [:schema Feature]]]])

(def ProvidesEntry
  [:map
   [:interface :keyword]
   [:input  :any]    ; a Malli schema, or [] / nil for empty payload
   [:output :any]])

(def SubProps
  [:map
   [:id :keyword]
   [:uses     {:optional true} [:vector :keyword]]
   [:provides {:optional true} [:map-of :any ProvidesEntry]]])

(def Subsystem
  [:catn [:tag [:enum :subsystem]] [:props SubProps]
   [:layers [:+ [:schema Layer]]]])

(def SysProps
  [:map
   [:id :keyword]
   [:tech        {:optional true} :string]
   [:desc        {:optional true} :string]
   [:provides    {:optional true} [:vector :keyword]]
   [:connects-to {:optional true} [:set [:tuple :keyword :keyword]]]])

(def System
  [:catn [:tag [:enum :system]] [:props SysProps]
   ;; a system's children are all layers OR all subsystems, never mixed
   [:body [:alt [:+ [:schema Layer]] [:+ [:schema Subsystem]]]]])

(def Root [:+ [:schema System]])

(defn check-structure
  "nil if the tree is structurally valid, else humanized Malli errors."
  [tree]
  (when-not (m/validate Root tree)
    (me/humanize (m/explain Root tree))))

;; ---- Tree-walk helpers ----

(defn- props [node] (second node))
(defn- node-tag [node] (first node))
(defn- system-subsystems [sys] (filter #(= :subsystem (node-tag %)) (drop 2 sys)))
(defn- system-layers [sys] (filter #(= :layer (node-tag %)) (drop 2 sys)))
(defn- subsystem-layers [sub] (drop 2 sub))
(defn- layer-features [layer] (rest layer))

(defn- all-layers [sys]
  (concat (system-layers sys)
          (mapcat subsystem-layers (system-subsystems sys))))

(defn- all-features [tree]
  (mapcat (fn [sys] (mapcat layer-features (all-layers sys))) tree))

(defn- all-ids [tree]
  (concat (map #(:id (props %)) tree)
          (map #(:id (props %)) (mapcat system-subsystems tree))
          (map #(:id (props %)) (all-features tree))))

;; ---- Reference & visibility integrity (level 2) ----

(defn check-references
  "Return a vector of human-readable reference/integrity problems (empty if clean)."
  [tree]
  (let [sys-by-id (into {} (map (juxt #(:id (props %)) identity) tree))
        problems  (atom [])
        add! (fn [m] (swap! problems conj m))]
    ;; connects-to integrity
    (doseq [sys tree
            [tsys tiface] (:connects-to (props sys))]
      (let [target (sys-by-id tsys)]
        (cond
          (nil? target)
          (add! (str (:id (props sys)) " connects-to unknown system " tsys))
          (not (some #{tiface} (:provides (props target))))
          (add! (str (:id (props sys)) " connects-to " tsys " " tiface
                     ", but that system does not provide it")))))
    ;; provides declaration <-> definition
    (doseq [sys tree]
      (let [declared (set (:provides (props sys)))
            defined  (set (mapcat (fn [sub] (map :interface (vals (:provides (props sub)))))
                                  (system-subsystems sys)))]
        (doseq [iface declared :when (not (defined iface))]
          (add! (str (:id (props sys)) " provides " iface
                     ", but no subsystem defines routes for it")))
        (doseq [iface defined :when (not (declared iface))]
          (add! (str (:id (props sys)) " has a route for " iface
                     ", but does not advertise it in :provides")))))
    ;; uses integrity
    (doseq [sys tree]
      (let [sub-ids (set (map #(:id (props %)) (system-subsystems sys)))]
        (doseq [sub (system-subsystems sys)
                used (:uses (props sub)) :when (not (sub-ids used))]
          (add! (str (:id (props sub)) " uses unknown subsystem " used)))))
    ;; unique ids
    (doseq [[id n] (frequencies (all-ids tree)) :when (> n 1)]
      (add! (str "duplicate id " id)))
    @problems))

;; ---- Route schema well-formedness (level 3) ----

(defn- empty-payload? [s] (or (nil? s) (and (vector? s) (empty? s))))

(defn check-schemas
  "Return problems for provider route :input/:output that are not valid,
   generatable Malli schemas. [] and nil mean empty payload and are skipped."
  [tree]
  (let [problems (atom [])]
    (doseq [sys tree
            sub (system-subsystems sys)
            [route entry] (:provides (props sub))
            k [:input :output]
            :let [s (get entry k)]
            :when (not (empty-payload? s))]
      (try
        (mg/generate s)
        (catch Exception e
          (swap! problems conj
                 (str (:id (props sub)) " route " (pr-str route) " " k
                      " is not a valid schema: " (or (ex-message e) "(no message)"))))))
    @problems))

;; ---- Core helpers ----

(defn load-tree
  "Evaluate a spec file in the babashka runtime (not sandboxed); its last form (nilify/root …) returns the tree."
  [path]
  (load-string (slurp path)))

(defn validate-all
  "Run all three validation passes on an already-loaded tree."
  [tree]
  (let [structure (check-structure tree)]
    (if structure
      {:structure structure :references [] :schemas []}
      {:structure nil
       :references (check-references tree)
       :schemas    (check-schemas tree)})))

;; ---- GitHub helpers ----

(defn- fetch-text [url]
  (let [resp (http/get url {:throw false})]
    (when (= 200 (:status resp))
      (:body resp))))

(defn- latest-version []
  (let [resp (http/get (str "https://api.github.com/repos/" repo "/releases/latest")
                       {:throw false :headers {"Accept" "application/vnd.github+json"}})]
    (when (= 200 (:status resp))
      (-> resp :body (json/parse-string true) :tag_name))))

;; ---- Commands ----

(def skills
  ["nilify" "author" "validate" "generate" "extract" "onboard" "diff"])

(defn- skill-target-dir [skill-name]
  (if (= skill-name "nilify")
    (io/file ".claude" "skills" "nilify")
    (io/file ".claude" "skills" (str "nilify-" skill-name))))

(defn cmd-init []
  (println "Initializing nilify project...")
  (let [nil-dir (io/file "nil")]
    (.mkdirs (io/file nil-dir "features"))
    (.mkdirs (io/file nil-dir "systems"))
    (println "  Created nil/features/ and nil/systems/"))
  (let [branch "main"]
    (doseq [skill-name skills]
      (let [url (str raw-url "/" branch "/skills/nilify/" skill-name "/SKILL.md")
            target (io/file (skill-target-dir skill-name) "SKILL.md")
            content (fetch-text url)
            deployed-name (if (= skill-name "nilify") "nilify" (str "nilify-" skill-name))]
        (if content
          (do (io/make-parents target)
              (spit target content)
              (println (str "  Deployed skill: " deployed-name)))
          (println (str "  Warning: could not fetch skill " skill-name " from " url))))))
  (println "Done."))

(defn cmd-validate [& [path]]
  (let [spec-path (or path "nil/root.clj")]
    (if-not (.exists (io/file spec-path))
      (do (println (str "No spec file at " spec-path
                        ". Run 'nilify init' first, or pass a path."))
          (System/exit 1))
      (let [tree (try
                   (load-tree spec-path)
                   (catch Exception e
                     (println (str "Could not evaluate " spec-path ": " (ex-message e)))
                     (System/exit 1)))
            {:keys [structure references schemas]} (validate-all tree)]
        (println (str "Validation results (" spec-path "):"))
        (if structure
          (do (println "  Structure: FAIL")
              (println (str "    " (pr-str structure)))
              (System/exit 1))
          (do
            (println "  Structure: ok")
            (println (str "  References: " (count references) " problem(s)"))
            (println (str "  Schemas: " (count schemas) " problem(s)"))
            (doseq [p (concat references schemas)] (println (str "  - " p)))
            (when (or (seq references) (seq schemas)) (System/exit 1))))))))

(defn cmd-update []
  (println "Checking for updates...")
  (let [self-path (System/getProperty "babashka.file")]
    (if-not self-path
      (println "Cannot determine own location. Update manually.")
      (let [url (str raw-url "/main/nilify")
            content (fetch-text url)]
        (if-not content
          (println "Could not fetch latest version from GitHub.")
          (let [new-version (second (re-find #"def version \"(.+?)\"" content))]
            (if (= version new-version)
              (println (str "Already at latest version " version "."))
              (do (spit self-path content)
                  (println (str "Updated " version " -> " new-version))))))))))

(defn cmd-version []
  (println (str "nilify " version)))

(def spec-reference
"; nilify spec reference -- every field documented in one place.
;
; A project's specs live in nil/. There are two spec formats:
;   1. Flat (EDN files in nil/features/ and nil/systems/) -- validated by `nilify validate`
;   2. Tree  (Clojure script using nilify.core) -- composes specs as data

;; ---------------------------------------------------------------------------
;; 1. Flat feature spec -- nil/features/<id>.clj
;; ---------------------------------------------------------------------------

{:id      :feat/compute                  ; required: unique keyword
 :desc    \"Evaluate Clojure expressions\" ; optional: natural-language purpose
 :tech    \"babashka\"                    ; optional: free-form tech hint
 :deps    [:feat/translate]              ; optional: feature ids this depends on
 :cases                                  ; optional: typed cases
 {:eval
  {:input   [:map [:expr :string]]       ; required: Malli schema for input
   :output  [:map [:result :double]]     ; required: Malli schema for output
   :desc    \"Parse and evaluate\"        ; optional: case-level description
   :examples                             ; optional: input/output pairs
   [{:in {:expr \"(+ 1 2)\"} :out {:result 3.0}}
    {:in {:expr \"(* 2 4)\"} :out {:result 8.0}}]}}}

;; ---------------------------------------------------------------------------
;; 2. Flat system spec -- nil/systems/<id>.clj
;; ---------------------------------------------------------------------------

{:id          :sys/calculator            ; required: unique keyword
 :desc        \"NL calculator\"           ; optional: description
 :components                             ; required: map of name -> {:feature :lang}
 {:translate {:feature :feat/translate :lang :python}
  :compute   {:feature :feat/compute   :lang :babashka}}
 :connections                            ; optional: data flow between components
 [[[:translate :translate :output]       ; from: [component case :input/:output]
   [:compute   :eval      :input]]]}     ; to:   [component case :input/:output]

;; ---------------------------------------------------------------------------
;; 3. Tree form -- composes specs as Clojure data
;; ---------------------------------------------------------------------------

(ns my-project
  (:require [nilify.core :as nilify]))

(def spec-query  [:map [:query :string]])   ; shared schemas as Clojure vars
(def spec-result [:map [:result :double]])

(def root (nilify/root
           [[:system                              ; node type
             {:id          :sys/backend           ; required
              :tech        \"http-server babashka\" ; optional: free-form tech
              :desc        \"REST API\"             ; optional
              :provides                           ; optional: exposed interfaces
              {[\"HTTP GET\" [\"/\"]]
               {:interface :iface/api             ; group routes by interface name
                :input     []
                :output    [:vector spec-result]}}
              :connects-to                        ; optional: consumed interfaces
              #{[:sys/external :iface/auth]}}

             [:layer                              ; layers ordered bottom-to-top
              [:feature                           ; foundational features go first
               {:id        :feat/domain-model
                :desc      \"Core domain types\"
                :internals {:domain-model spec-result}}]]

             [:layer                              ; upper layer depends on lower
              [:feature
               {:id        :feat/api
                :tech      \"compojure\"            ; per-feature tech override
                :desc      (nilify/prompt
                            \"Provides :iface/api\"
                            \"Routes documented in :provides above.\")}]]]]))

;; ---------------------------------------------------------------------------
;; Naming conventions (by convention, not enforced)
;; ---------------------------------------------------------------------------

;; :sys/<name>            system ids
;; :feat/<name>           feature ids
;; :iface/<name>          interface names (for :provides / :connects-to)
;; :<feature>/<field>     schema fields owned by a feature (e.g. :domain-model/id)
")

(defn cmd-spec []
  (println spec-reference))

(defn cmd-help []
  (println "nilify - system specification language for LLM-fused development")
  (println)
  (println "Usage: nilify <command>")
  (println)
  (println "Commands:")
  (println "  init       Create nil/ folders and deploy skills into .claude/skills/")
  (println "  validate   Validate specs in nil/features/ and nil/systems/")
  (println "  spec       Print the complete spec reference")
  (println "  update     Update nilify CLI to the latest version")
  (println "  version    Show version")
  (println "  help       Show this help"))

;; ---- Main ----

(defn -main [& args]
  (let [cmd (first args)]
    (case cmd
      "init"     (cmd-init)
      "validate" (apply cmd-validate (rest args))
      "spec"     (cmd-spec)
      "update"   (cmd-update)
      "version"  (cmd-version)
      "help"     (cmd-help)
      nil        (cmd-help)
      (do (println (str "Unknown command: " cmd))
          (cmd-help)
          (System/exit 1)))))

(when (= *file* (System/getProperty "babashka.file"))
  (apply -main *command-line-args*))
