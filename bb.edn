{:paths ["src" "test"]
 :deps  {metosin/malli {:mvn/version "0.20.1"}}
 :tasks {test {:doc  "Run all nilify tests"
               :task (let [{:keys [out err exit]} (clojure.java.shell/sh "bb" "test/runner.clj")]
                       (print out) (when (seq err) (binding [*out* *err*] (print err)))
                       (flush)
                       (System/exit exit))}}}
